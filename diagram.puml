@startuml SmartHomeDevicesSystem

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam backgroundColor #1e1e2e
skinparam ArrowColor #89b4fa
skinparam ClassBorderColor #585b70
skinparam ClassFontColor #cdd6f4
skinparam ClassAttributeFontColor #cdd6f4
skinparam ClassStereotypeFontColor #a6e3a1
skinparam NoteFontColor #cdd6f4
skinparam NoteBackgroundColor #313244
skinparam NoteBorderColor #585b70

skinparam class {
    BackgroundColor #313244
    HeaderBackgroundColor #45475a
    FontColor #cdd6f4
    AttributeFontColor #cdd6f4
    BorderColor #585b70
}

skinparam interface {
    BackgroundColor #1e3a5f
    HeaderBackgroundColor #1d4ed8
    FontColor #bfdbfe
    AttributeFontColor #bfdbfe
    BorderColor #3b82f6
}

' ─────────────────────────────────────────
'  INTERFACES
' ─────────────────────────────────────────

interface SmartComponent {
    + turnOn() : void
    + turnOff() : void
    + getName() : string
    + getId() : string
    + getStatus() : DeviceStatus
}

interface SmartDeviceFactory {
    + createLight(type : string) : AbstractSmartLight*
    + createThermostat(type : string) : AbstractSmartThermostat*
    + createCamera(type : string) : AbstractSmartCamera*
    + createDoorLock() : AbstractDoorLock*
    + createMotionSensor() : AbstractMotionSen*
}

interface AbstractSmartLight {
    + turnOn() : void
    + turnOff() : void
    + adjustbrightness(level : int) : bool
    + getType() : string
    + getId() : string
    + getName() : string
    + getStatus() : DeviceStatus
}

interface AbstractSmartThermostat {
    + setTargetTemperature(temp : double) : void
    + getTargetTemperature() : double
    + getCurrentTemperature() : double
    + setMode(mode : ThermoMode) : void
    + getMode() : ThermoMode
    + turnOn() : void
    + turnOff() : void
}

interface AbstractSmartCamera {
    + startRecording() : void
    + stopRecording() : void
    + enableNightVision() : void
    + disableNightVision() : void
    + isRecording() : bool
    + turnOn() : void
    + turnOff() : void
}

interface AbstractDoorLock {
    + lock() : void
    + unlock() : void
    + isLocked() : bool
}

interface AbstractMotionSen {
    + detectMotion() : bool
    + setSensitivity(level : int) : void
    + getSensitivity() : int
}

interface Observer {
    + update(device : SmartDevice*) : void
}

interface Subject {
    + attach(o : Observer*) : void
    + detach(o : Observer*) : void
    + notify() : void
}

interface Command {
    + execute() : void
    + undo() : void
}

interface AutomationModeStrategy {
    + applyMode(hub : SmartHomeHub*) : void
    + getModeName() : string
}

interface DeviceState {
    + turnOn(device : SmartDevice*) : void
    + turnOff(device : SmartDevice*) : void
    + dim(device : SmartDevice*, level : int) : void
    + getStateName() : string
}

' ─────────────────────────────────────────
'  CORE CLASSES
' ─────────────────────────────────────────

class Client {
    - hub : SmartHomeHub*
    - controller : AutomationController*
    + Client()
    + ~Client()
    + setupSystem() : void
    + run() : void
}

class SmartHomeHub {
    - devices : vector<SmartDevice*>
    - devicesByZone : map<string, vector<SmartDevice*>>
    - factory : SmartDeviceFactory*
    - currentMode : AutomationModeStrategy*
    + SmartHomeHub(factory : SmartDeviceFactory*)
    + ~SmartHomeHub()
    + addDevice(type : string, zone : string) : SmartDevice*
    + removeDevice(deviceId : string) : void
    + controlDevice(deviceId : string, action : string) : void
    + executeAutomation(command : Command*) : void
    + setMode(mode : AutomationModeStrategy*) : void
    + getDevicesByZone(zone : string) : vector<SmartDevice*>
    + getAllDevices() : vector<SmartDevice*>&
}

class SmartDevice {
    - id : string
    - name : string
    - brand : string
    - status : DeviceStatus
    - location : string
    - observers : list<Observer*>
    - currentState : DeviceState*
    + SmartDevice(id, name, brand : string)
    + ~SmartDevice()
    + turnOn() : void
    + turnOff() : void
    + dim(level : int) : void
    + getId() : string
    + getName() : string
    + getBrand() : string
    + getStatus() : DeviceStatus
    + setLocation(loc : string) : void
    + getLocation() : string
    + attach(o : Observer*) : void
    + detach(o : Observer*) : void
    + notify() : void
    + setState(state : DeviceState*) : void
    + getCurrentState() : DeviceState*
}

' ─────────────────────────────────────────
'  COMPOSITE PATTERN
' ─────────────────────────────────────────

class DeviceComposite {
    - groupId : string
    - groupName : string
    - groupType : string
    - children : vector<SmartComponent*>
    + DeviceComposite(id, name, type : string)
    + ~DeviceComposite()
    + add(component : SmartComponent*) : void
    + rem(component : SmartComponent*) : void
    + getChildren() : vector<SmartComponent*>
    + turnOn() : void
    + turnOff() : void
    + getName() : string
    + getId() : string
    + getStatus() : DeviceStatus
}

class RoomComposite {
    - roomType : string
    + RoomComposite(id, name, roomType : string)
    + getRoomType() : string
}

class FloorComposite {
    - floorNumber : int
    + FloorComposite(id, name : string, floorNumber : int)
    + getFloorNumber() : int
}

class FunctionalComposite {
    - functionType : string
    + FunctionalComposite(id, name, functionType : string)
    + getFunctionType() : string
}

' ─────────────────────────────────────────
'  ABSTRACT FACTORY PATTERN
' ─────────────────────────────────────────

class BasicFactory {
    + createLight(type : string) : AbstractSmartLight*
    + createThermostat(type : string) : AbstractSmartThermostat*
    + createCamera(type : string) : AbstractSmartCamera*
    + createDoorLock() : AbstractDoorLock*
    + createMotionSensor() : AbstractMotionSen*
}

class PremiumFactory {
    + createLight(type : string) : AbstractSmartLight*
    + createThermostat(type : string) : AbstractSmartThermostat*
    + createCamera(type : string) : AbstractSmartCamera*
    + createDoorLock() : AbstractDoorLock*
    + createMotionSensor() : AbstractMotionSen*
}

' ── Lights ──
class BasicLedLight {
    - id : string
    - name : string
    - brand : string
    - status : DeviceStatus
    + turnOn() : void
    + turnOff() : void
    + adjustbrightness(level : int) : bool
    + getType() : string
    + getId() : string
    + getName() : string
    + getStatus() : DeviceStatus
}

class BasicHalLight {
    - id : string
    - name : string
    - brand : string
    - status : DeviceStatus
    + turnOn() : void
    + turnOff() : void
    + adjustbrightness(level : int) : bool
    + getType() : string
    + getId() : string
    + getName() : string
    + getStatus() : DeviceStatus
}

class PremiumLedLight {
    - id : string
    - name : string
    - brand : string
    - brightness : int
    - state : LightState
    + turnOn() : void
    + turnOff() : void
    + adjustbrightness(level : int) : bool
    + setBrightness(level : int) : void
    + getBrightness() : int
    + getLightState() : LightState
    + getType() : string
    + getId() : string
    + getName() : string
    + getStatus() : DeviceStatus
}

class PremiumHalogenLight {
    - id : string
    - name : string
    - brand : string
    - brightness : int
    - state : LightState
    + turnOn() : void
    + turnOff() : void
    + adjustbrightness(level : int) : bool
    + getType() : string
    + getId() : string
    + getName() : string
    + getStatus() : DeviceStatus
}

