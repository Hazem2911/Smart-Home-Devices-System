' ─────────────────────────────────────────
'  ADAPTER PATTERN
' ─────────────────────────────────────────

class LegacyDevice {
    - externalId : string
    - vendorName : string
    - protocolType : string
    - isConnected : bool
    - rawState : string
    + LegacyDevice(externalId, vendorName, protocolType : string)
    + connect() : void
    + disconnect() : void
    + sendCommand(cmd : string) : void
    + getStatus() : string
}

class LegacyDeviceAdapter {
    - externalDevice : LegacyDevice*
    - adapterVersion : string
    - protocolSynced : bool
    + LegacyDeviceAdapter(id, name : string, device : LegacyDevice*, version : string)
    + ~LegacyDeviceAdapter()
    + turnOn() : void
    + turnOff() : void
    + getStatus() : DeviceStatus
    + control() : void
    - translateCommand(cmd : string) : string
}

' ─────────────────────────────────────────
'  OBSERVER PATTERN
' ─────────────────────────────────────────

class AutomationController {
    - monitoredDevices : list<SmartDevice*>
    - historyCommands : vector<Command*>
    + AutomationController()
    + ~AutomationController()
    + update(device : SmartDevice*) : void
    + addCommand(cmd : Command*) : void
    + executeCommand(cmd : Command*) : void
}

' ─────────────────────────────────────────
'  COMMAND PATTERN
' ─────────────────────────────────────────

class TurnLightONComm {
    - device : SmartDevice*
    + TurnLightONComm(dev : SmartDevice*)
    + execute() : void
    + undo() : void
}

class TurnLightOFFComm {
    - device : SmartDevice*
    + TurnLightOFFComm(dev : SmartDevice*)
    + execute() : void
    + undo() : void
}

' ─────────────────────────────────────────
'  STRATEGY PATTERN
' ─────────────────────────────────────────

class ComfortAutomationMode {
    - temperatureLevel : int
    - brightnessLevel : int
    + ComfortAutomationMode(temp : int, brightness : int)
    + applyMode(hub : SmartHomeHub*) : void
    + getModeName() : string
}

class EnergySavingMode {
    - maxAllowedDevices : int
    - autoShutdownDelay : int
    + EnergySavingMode(maxDevices : int, shutdownDelay : int)
    + applyMode(hub : SmartHomeHub*) : void
    + getModeName() : string
}

' ─────────────────────────────────────────
'  STATE PATTERN
' ─────────────────────────────────────────

class LightOnState {
    - brightnessLevel : int
    + LightOnState(brightness : int)
    + turnOn(device : SmartDevice*) : void
    + turnOff(device : SmartDevice*) : void
    + dim(device : SmartDevice*, level : int) : void
    + getStateName() : string
}

class LightOffState {
    + turnOn(device : SmartDevice*) : void
    + turnOff(device : SmartDevice*) : void
    + dim(device : SmartDevice*, level : int) : void
    + getStateName() : string
}

class LightDimmedState {
    - brightnessLevel : int
    + LightDimmedState(brightness : int)
    + turnOn(device : SmartDevice*) : void
    + turnOff(device : SmartDevice*) : void
    + dim(device : SmartDevice*, level : int) : void
    + getStateName() : string
}

' ─────────────────────────────────────────
'  INHERITANCE
' ─────────────────────────────────────────

SmartComponent          <|.. SmartDevice
SmartComponent          <|.. DeviceComposite
DeviceComposite         <|-- RoomComposite
DeviceComposite         <|-- FloorComposite
DeviceComposite         <|-- FunctionalComposite

SmartDeviceFactory      <|.. BasicFactory
SmartDeviceFactory      <|.. PremiumFactory

AbstractSmartLight      <|.. BasicLedLight
AbstractSmartLight      <|.. BasicHalLight
AbstractSmartLight      <|.. PremiumLedLight
AbstractSmartLight      <|.. PremiumHalogenLight

AbstractSmartThermostat <|.. BasicSmartThermoA
AbstractSmartThermostat <|.. BasicSmartThermoB
AbstractSmartThermostat <|.. PremiumSmartThermoA
AbstractSmartThermostat <|.. PremiumSmartThermoB

AbstractSmartCamera     <|.. BasicWiredCamera
AbstractSmartCamera     <|.. BasicWirelessCamera
AbstractSmartCamera     <|.. PremiumWiredCamera
AbstractSmartCamera     <|.. PremiumWirelessCamera

Subject                 <|.. SmartDevice
Observer                <|.. AutomationController

Command                 <|.. TurnLightONComm
Command                 <|.. TurnLightOFFComm

AutomationModeStrategy  <|.. ComfortAutomationMode
AutomationModeStrategy  <|.. EnergySavingMode

DeviceState             <|.. LightOnState
DeviceState             <|.. LightOffState
DeviceState             <|.. LightDimmedState

SmartDevice             <|-- LegacyDeviceAdapter

' ─────────────────────────────────────────
'  COMPOSITION / AGGREGATION
' ─────────────────────────────────────────

Client                  "1" o-- "1"   SmartHomeHub          : uses
Client                  "1" o-- "1"   AutomationController  : owns

SmartHomeHub            "1" o-- "1"   SmartDeviceFactory    : uses
SmartHomeHub            "1" o-- "0..*" SmartDevice          : manages
SmartHomeHub            "1" o-- "0..1" AutomationModeStrategy : has

DeviceComposite         "1" o-- "0..*" SmartComponent       : contains

SmartDevice             "1" *-- "1"   DeviceState           : has state
SmartDevice             "1" o-- "0..*" Observer             : notifies

LegacyDeviceAdapter     "1" *-- "1"   LegacyDevice          : wraps

AutomationController    "1" o-- "0..*" Command              : history

' ─────────────────────────────────────────
'  DEPENDENCIES
' ─────────────────────────────────────────

BasicFactory    ..> BasicLedLight
BasicFactory    ..> BasicHalLight
BasicFactory    ..> BasicSmartThermoA
BasicFactory    ..> BasicSmartThermoB
BasicFactory    ..> BasicWiredCamera
BasicFactory    ..> BasicWirelessCamera

PremiumFactory  ..> PremiumLedLight
PremiumFactory  ..> PremiumHalogenLight
PremiumFactory  ..> PremiumSmartThermoA
PremiumFactory  ..> PremiumSmartThermoB
PremiumFactory  ..> PremiumWiredCamera
PremiumFactory  ..> PremiumWirelessCamera

TurnLightONComm  ..> SmartDevice
TurnLightOFFComm ..> SmartDevice

ComfortAutomationMode ..> SmartHomeHub
EnergySavingMode      ..> SmartHomeHub

LightOnState    ..> SmartDevice
LightOffState   ..> SmartDevice
LightDimmedState ..> SmartDevice

@enduml
