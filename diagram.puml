    - name : string
    - brand : string
    + setTargetTemperature(temp : double) : void
    + getTargetTemperature() : double
    + getCurrentTemperature() : double
    + setMode(mode : ThermoMode) : void
    + getMode() : ThermoMode
    + turnOn() : void
    + turnOff() : void
