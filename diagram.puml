class PremiumSmartThermoA {
    - id : string
    - name : string
    - brand : string
    - currentTemperature : double
    - targetTemperature : double
    - mode : ThermoMode
    + setTargetTemperature(temp : double) : void
    + getTargetTemperature() : double
    + getCurrentTemperature() : double
    + setMode(mode : ThermoMode) : void
    + getMode() : ThermoMode
    + turnOn() : void
    + turnOff() : void
}

class PremiumSmartThermoB {
    - id : string
    - name : string
    - brand : string
    - currentTemperature : double
    - targetTemperature : double
    - mode : ThermoMode
    + setTargetTemperature(temp : double) : void
    + getTargetTemperature() : double
    + getCurrentTemperature() : double
    + setMode(mode : ThermoMode) : void
    + getMode() : ThermoMode
    + turnOn() : void
    + turnOff() : void
}

' ── Cameras ──
class BasicWiredCamera {
    - id : string
    - name : string
    - brand : string
    - recording : bool
    + startRecording() : void
    + stopRecording() : void
    + enableNightVision() : void
    + disableNightVision() : void
    + isRecording() : bool
    + turnOn() : void
    + turnOff() : void
}

class BasicWirelessCamera {
    - id : string
    - name : string
    - brand : string
    - recording : bool
    + startRecording() : void
    + stopRecording() : void
    + enableNightVision() : void
    + disableNightVision() : void
    + isRecording() : bool
    + turnOn() : void
    + turnOff() : void
